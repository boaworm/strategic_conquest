{
  "name": "@sc/trainer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node --enable-source-maps dist/index.js",
    "train": "npx tsx src/index.ts",
    "collect": "npx tsc -p ../shared/tsconfig.json && npm run build && npx tsx src/collect_data.ts",
    "nn-sim": "npx tsx src/nn_simulator.ts",
    "record": "npx tsx src/record_replay.ts",
    "replay": "npx tsx src/replay_picker.ts"
  },
  "dependencies": {
    "@sc/shared": "*"
  }
}
